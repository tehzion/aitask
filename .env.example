VITE_AITASK_BACKEND=local
VITE_AITASK_SHOW_DEMO_LOGIN=true
VITE_AITASK_ALLOW_PASSWORD_RESET_BYPASS=true
VITE_AITASK_LOCAL_DEFAULT_PASSWORD=password123

